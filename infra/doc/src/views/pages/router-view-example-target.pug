extends ../layouts/main

block append head
  - pageTitle = "Router View Example Target"
  - bodyId = "router-view-example-target"

block content
  router-view#example-view(
    listen-all-links="false"
    listen-popstate="false"
    scroll-to-top="false"
    scroll-to-anchor-hash="false"
    change-browser-url="false"
    prefetch-links="false"
  )
    .container.py-5
      .row
        .col-12
          h1.h4.mb-3 Nested View Target
          p.mb-4
            | This content is loaded only inside the nested router view demo container.
          a.btn.btn-outline-primary(
            rv-route="{'url': 'router-components.html', 'viewId': 'example-view'}"
            href="router-components.html"
          ) Back to Router Docs
