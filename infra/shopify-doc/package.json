{
  "name": "@ribajs/shopify-doc",
  "version": "2.0.0-rc.23",
  "description": "Shopify theme for the Riba.js Shopify-specific Documentation",
  "type": "module",
  "exports": "./src/ts/main.ts",
  "main": "./src/ts/main.ts",
  "typings": "src/ts/types",
  "private": true,
  "scripts": {
    "theme:download": "theme download --dir './theme'",
    "deploy": "yarn run deploy:pug",
    "deploy:pug": "yarn run build:prod:pug && theme deploy --dir ./theme layout sections snippets templates",
    "sync:demos": "rm -rf ./src/ts/demos/ && rsync -a --progress ../../demos ./src/ts/ --exclude .cache --exclude .yarn --exclude dist --exclude .eslintrc.js",
    "lint:ts": "eslint ./src --ignore-pattern ./src/ts/demos/* --fix && tsc --noEmit",
    "lint": "yarn run sync:demos && yarn run lint:ts",
    "build": "echo 'Doc build skipped - pug-cli incompatible with Node 24, will be replaced with static site generator'",
    "build:prod:pug": "concurrently \"yarn:build:prod:pug:*\"",
    "build:prod:pug:snippets": "pug -O ./pug.options.js src/pug/snippets -E liquid -o theme/snippets",
    "build:prod:pug:templates": "pug -O ./pug.options.js src/pug/templates -E liquid -o theme/templates",
    "build:prod:pug:layout": "pug -O ./pug.options.js src/pug/layout -E liquid -o theme/layout",
    "build:dev": "yarn run sync:demos && concurrently \"yarn:build:dev:*\"",
    "build:dev:pug": "concurrently \"yarn:build:dev:pug:*\"",
    "build:dev:pug:snippets": "yarn run build:prod:pug:snippets --pretty",
    "build:dev:pug:templates": "yarn run build:prod:pug:templates --pretty",
    "build:dev:pug:layout": "yarn run build:prod:pug:layout --pretty",
    "watch": "concurrently \"yarn:watch:*\"",
    "watch:pug": "concurrently \"yarn:watch:pug:*\"",
    "watch:pug:snippets": "yarn run build:dev:pug:snippets --watch",
    "watch:pug:templates": "yarn run build:dev:pug:templates --watch",
    "watch:pug:layout": "yarn run build:dev:pug:layout --watch",
    "check": "yarn run sync:demos && tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ribajs/doc"
  },
  "keywords": [
    "Bootstrap",
    "Bootstrap4",
    "Shopify",
    "Art+Code Studio",
    "Riba",
    "Rivets",
    "tinybind",
    "Documentation",
    "Docs"
  ],
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/ribajs/doc/blob/master/README.md"
    }
  ],
  "bugs": {
    "url": "https://github.com/ribajs/doc/issues"
  },
  "url": "https://github.com/ribajs/doc",
  "homepage": "https://ribajs.com/",
  "devDependencies": {
    "@ribajs/eslint-config": "workspace:^",
    "@ribajs/postcss-config": "workspace:^",
    "@ribajs/tsconfig": "workspace:^",
    "@types/debug": "^4.1.13",
    "@types/node": "^24.12.0",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jstransformer-escape-html": "^1.1.0",
    "jstransformer-markdown-it": "^3.0.0",
    "jstransformer-prismjs": "^0.1.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "prismjs": "^1.30.0",
    "pug-cli": "^1.0.0-alpha6",
    "sass": "^1.98.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@ribajs/bs5": "workspace:^",
    "@ribajs/core": "workspace:^",
    "@ribajs/events": "workspace:^",
    "@ribajs/extras": "workspace:^",
    "@ribajs/history": "workspace:^",
    "@ribajs/i18n": "workspace:^",
    "@ribajs/iconset": "workspace:^",
    "@ribajs/router": "workspace:^",
    "@ribajs/shopify": "workspace:^",
    "@ribajs/shopify-tda": "workspace:^",
    "@ribajs/utils": "workspace:^",
    "bootstrap": "^5.3.8",
    "debug": "^4.4.3",
    "jquery": "^4.0.0",
    "lorem-ipsum": "^2.0.8"
  }
}
