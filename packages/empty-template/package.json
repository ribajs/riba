{
  "name": "@ribajs/empty-template",
  "description": "Empty Riba.js module, can be used as template for new modules",
  "version": "2.0.0-rc.23",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx,.cts,.mts --fix && tsc --noEmit",
    "build:module": "tsc",
    "clean": "rm -rf ./dist ./lib",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@ribajs/core": "workspace:^",
    "@ribajs/jsx": "workspace:^",
    "@ribajs/utils": "workspace:^"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "devDependencies": {
    "@ribajs/tsconfig": "workspace:^",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "typescript": "6.0.2"
  }
}
