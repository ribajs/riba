{
  "name": "@ribajs/fuse",
  "description": "Riba.js module with utilities based on Fuse.js",
  "version": "2.0.0-rc.23",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx,.cts,.mts --fix && tsc --noEmit",
    "build": "yarn run lint && yarn run build:module",
    "build:module": "tsc",
    "clean": "rm -rf ./dist ./lib",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@ribajs/core": "workspace:^",
    "@ribajs/jsx": "workspace:^",
    "@ribajs/utils": "workspace:^",
    "fuse.js": "^7.1.0"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "devDependencies": {
    "@ribajs/tsconfig": "workspace:^",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "typescript": "6.0.2"
  }
}
