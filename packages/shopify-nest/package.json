    "@ribajs/events": "workspace:^",
    "@ribajs/i18n": "workspace:^",
    "@ribajs/shopify-easdk": "workspace:^",
    "@ribajs/shopify-tda": "workspace:^",
    "@ribajs/utils": "workspace:^",
    "@types/debug": "^4.1.13",
    "debug": "^4.4.3",
    "monaco-editor": "^0.55.1"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "devDependencies": {
    "@ribajs/tsconfig": "workspace:^",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "typescript": "6.0.2"
  }
