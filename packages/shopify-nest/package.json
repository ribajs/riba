{
  "name": "@ribajs/shopify-nest",
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx,.cts,.mts --fix && tsc --noEmit",
    "build:module": "tsc",
    "clean": "rm -rf ./dist ./lib",
    "check": "tsc --noEmit"
