    "@ribajs/types": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-config": "^30.3.0",
    "jest-extended": "^7.0.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "typescript": "6.0.2"
