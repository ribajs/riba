{
  "name": "@ribajs/core",
  "description": "Core module of Riba.js",
  "version": "2.0.0-rc.23",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "contributors": [
    "Michael Richards",
    "Luiz Américo Pereira Câmara"
  ],
  "url": "https://github.com/ribajs/riba/tree/master/packages/core",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "sass": "src/scss/index.scss",
