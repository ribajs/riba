{
  "name": "@ribajs/artcodestudio",
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "yarn run clean && yarn run lint && jest --config=jest.config.cjs",
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx,.cts,.mts --fix && tsc --noEmit",
    "build:module": "tsc",
    "clean": "rm -rf ./dist ./lib",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@ribajs/bs5": "workspace:^",
    "@ribajs/core": "workspace:^",
    "@ribajs/utils": "workspace:^"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "devDependencies": {
    "@ribajs/eslint-config": "workspace:^",
    "@ribajs/tsconfig": "workspace:^",
    "@ribajs/types": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@yarnpkg/pnpify": "^4.1.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "typescript": "6.0.2"
  }
}
