{
  "name": "@ribajs/artcodestudio",
  "version": "2.0.0-rc.23",
  "type": "module",
  "engines": {
    "node": "^12.20.0 || ^14.13.1 || >=16.0.0"
  },
  "scripts": {
    "test": "yarn run clean && yarn run lint && jest --config=jest.config.cjs",
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx,.cts,.mts --fix && tsc --noEmit",
    "build": "yarn run lint && yarn run build:module",
    "build:module": "tsc",
    "clean": "rm -rf ./dist ./lib"
  },
  "dependencies": {
    "@ribajs/bs5": "workspace:^",
    "@ribajs/core": "workspace:^",
    "@ribajs/utils": "workspace:^"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "source": "src/index.ts",
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-syntax-export-default-from": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.27.4",
    "@babel/plugin-transform-typescript": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.27.6",
    "@babel/runtime-corejs3": "^7.27.6",
    "@ribajs/eslint-config": "workspace:^",
    "@ribajs/tsconfig": "workspace:^",
    "@ribajs/types": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@yarnpkg/pnpify": "^4.1.5",
    "babel-jest": "^30.0.0",
    "babel-loader": "^10.0.0",
    "babel-plugin-array-includes": "^2.0.3",
    "core-js": "^3.43.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "jest": "^30.0.0",
    "jest-extended": "^6.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "typescript": "5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
