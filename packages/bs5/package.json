  "repository": {
    "type": "git",
    "url": "git+https://github.com/ribajs/riba.git"
  },
  "keywords": [
    "Bootstrap",
    "Twitter Bootstrap",
    "Bootstrap 5",
    "Twitter Bootstrap 5",
    "Art+Code Studio",
    "Riba",
    "Rivets",
