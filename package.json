{
  "name": "ribajs",
  "description": "Declarative data binding + template solution.",
  "version": "2.0.0-rc.23",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true,
  "author": "Art+Code Studio (Pascal Garber) <pascal@artandcode.studio>",
  "contributors": [],
  "main": "src/index.ts",
  "url": "https://github.com/ribajs/riba",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/ribajs/riba/blob/master/LICENSE"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ribajs/riba.git"
  },
  "keywords": [
    "Bootstrap",
    "Bootstrap5",
    "Shopify",
    "Art+Code Studio",
    "Riba",
    "Rivets",
    "tinybind",
    "SPA",
    "TypeScript",
    "Browser"
  ],
  "scripts": {
    "reinstall": "YARN_CHECKSUM_BEHAVIOR=update yarn install && yarn dlx @yarnpkg/sdks vscode",
    "test": "jest --config=jest.config.js",
    "test:watch": "jest --config=jest.config.js --watch",
    "test:clear": "jest --config=jest.config.js --clearCache",
    "lint": "yarn run lint:ext && yarn workspaces foreach -v -p -W run lint",
    "lint:ext": "node lint-file-extension.js",
    "build:all": "yarn workspaces foreach -v -W --jobs 5 run build",
    "build:libs": "yarn workspaces foreach -v -p -W --no-private --jobs 5 run build",
    "clean": "yarn workspaces foreach -v -p -W run clean",
    "bump:prerelease": "yarn workspaces foreach -v version prerelease",
    "bump:patch": "yarn workspaces foreach -v --all version patch",
    "bump:minor": "yarn workspaces foreach -v --all version minor",
    "bump:major": "yarn workspaces foreach -v --all version major",
    "publish:next": "yarn workspaces foreach -v -W --no-private npm publish --tolerate-republish --tag next --access public",
    "publish:latest": "yarn workspaces foreach -v -W --no-private npm publish --tolerate-republish --tag latest --access public",
    "check:all": "yarn workspaces foreach -v -p -j 5 run check"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@ribajs/eslint-config": "workspace:^",
    "@ribajs/tsconfig": "workspace:^",
    "@ribajs/types": "workspace:^",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@yarnpkg/pnpify": "^4.1.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-config": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-extended": "^7.0.0",
    "jest-ts-webcompat-resolver": "^1.0.1",
    "jest-util": "^30.3.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "packages/*",
    "vendor/*",
    "infra/*",
    "!infra/cli",
    "!infra/schematics",
    "backend/*",
    "demos/*",
    "examples/*/*",
    "!examples/electron/electron",
    "!examples/electron/electron-nest"
  ],
  "dependenciesMeta": {
    "prettier": {
      "unplugged": true
    }
  },
  "resolutions": {
    "@ribajs/bs5": "workspace:^",
    "@ribajs/content-slider": "workspace:^",
    "@ribajs/octobercms": "workspace:^",
    "@ribajs/leaflet-map": "workspace:^",
    "@ribajs/cache": "workspace:^",
    "@ribajs/core": "workspace:^",
    "@ribajs/extras": "workspace:^",
    "@ribajs/events": "workspace:^",
    "@ribajs/history": "workspace:^",
    "@ribajs/i18n": "workspace:^",
    "@ribajs/iconset": "workspace:^",
    "@ribajs/jquery": "workspace:^",
    "@ribajs/moment": "workspace:^",
    "@ribajs/photoswipe": "workspace:^",
    "@ribajs/router": "workspace:^",
    "@ribajs/shopify": "workspace:^",
    "@ribajs/shopify-easdk": "workspace:^",
    "@ribajs/shopify-tda": "workspace:^",
    "@ribajs/utils": "workspace:^",
    "@ribajs/doc": "workspace:^",
    "@ribajs/shopify-doc": "workspace:^",
    "@ribajs/eslint-config": "workspace:^",
    "@ribajs/types": "workspace:^",
    "@ribajs/vite-config": "workspace:^",
    "@ribajs/tsconfig": "workspace:^",
    "@ribajs/nest-theme": "workspace:^",
    "@ribajs/npm-package": "workspace:^",
    "@ribajs/strapi": "workspace:^"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "glob": "^13.0.6",
    "pug": "^3.0.4"
  },
  "packageManager": "yarn@4.13.0"
}
